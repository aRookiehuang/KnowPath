{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "src/vite-env.d.ts",
    "src/main.ts",
    "src/App.vue",
    "src/router/index.ts",
    "src/stores/user.ts",
    "src/api/**/*.ts",
    "src/utils/**/*.ts",
    "src/components/ui/**/*.vue",
    "src/views/Home.vue",
    "src/views/Login.vue",
    "src/views/Register.vue",
    "src/views/Dashboard.vue",
    "src/views/GoalConversation.vue",
    "src/views/LearningPaths.vue",
    "src/views/LearningPathDetail.vue",
    "src/views/LearningState.vue",
    "src/views/Achievements.vue",
    "src/views/LearningPage.vue",
    "src/views/DialogueLearningPage.vue",
    "src/views/ClassTest.vue",
    "src/views/DeveloperDocs.vue",
    "src/views/Profile.vue",
    "src/views/user/AgentLogs.vue",
    "src/views/admin/Login.vue",
    "src/views/admin/Dashboard.vue",
    "src/views/admin/Overview.vue",
    "src/views/admin/Users.vue",
    "src/views/admin/ApiConfig.vue",
    "src/views/admin/ExecutionLogs.vue"
  ],
  "exclude": ["dist", "node_modules"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
