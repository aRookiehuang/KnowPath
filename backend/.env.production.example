# 生产环境配置示例
# 复制此文件为 .env.production 并修改配置

# 服务器配置
NODE_ENV=production
PORT=3001

# CORS 配置 (多个来源用逗号分隔)
CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com

# 数据库配置 (PostgreSQL)
DATABASE_URL="postgresql://wenflow:your_password@localhost:5432/wenflow"

# JWT 配置 (生产环境必须使用强密钥！)
# 生成方法：openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-must-be-strong
JWT_EXPIRES_IN=7d

# AI 服务配置 (生产环境)
AI_API_URL=https://your-ai-service.com
AI_API_KEY=sk-your-production-api-key
AI_MODEL=gem-4-flash

# 课程设计 AI 配置 (可选，用于 ContentAgent)
COURSE_DESIGN_API_URL=https://your-ai-service.com
COURSE_DESIGN_API_KEY=sk-your-production-api-key
COURSE_DESIGN_MODEL=gem-4-flash

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=3600000
CACHE_MAX_SIZE=1000

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=/var/log/wenflow/

# 监控配置
MONITORING_ENABLED=true
METRICS_ENDPOINT=/api/admin/metrics

# 安全配置
CORS_ORIGINS=https://your-domain.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# ContentAgent 特定配置
CONTENT_AGENT_CACHE_ENABLED=true
CONTENT_AGENT_CACHE_TTL=3600000
CONTENT_AGENT_MAX_ROUNDS=8

# 会话配置
SESSION_SECRET=your-session-secret-key-change-in-production
SESSION_TIMEOUT=86400000

# 文件上传配置 (如果支持)
MAX_FILE_SIZE=10485760
UPLOAD_PATH=/var/uploads/

# 邮件配置 (如果需要邮件通知)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
SMTP_FROM=WenFlow <noreply@your-domain.com>

# 备份配置
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400000
BACKUP_PATH=/var/backups/wenflow/
